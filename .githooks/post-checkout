#!/usr/bin/env bash
# installed-by: ivt-hooks
# post-checkout hook: enforce Investtal branch-naming policy.
#
# Git has no "pre-checkout" hook, so we validate on post-checkout and bounce
# back to the previous branch when the new branch violates the policy.
#
# Bypass:
#   - detached HEAD (no branch name) is always allowed
#   - checkout from a non-branch ref (e.g. `git checkout <sha>`) is allowed
#   - set IVT_HOOK_SKIP=1 in the environment to skip this hook entirely
#
# Chaining:
#   A previously-installed post-checkout hook is preserved as
#   .git/hooks/post-checkout.pre-ivt and run AFTER this hook's own work
#   (e.g. graphify's graph rebuild). If we switch back, we deliberately do
#   NOT run the chained hook again — the user is no longer on the rejected
#   branch, so its side effects would be wrong.

set -u

# ----- locate the shared lib relative to this hook file ---------------------
# Resolve this hook's own directory, dereferencing symlinks. Portable across
# macOS bash 3.2 (BSD readlink, no -f), macOS 12.3+ (readlink -f), and Linux
# (GNU readlink -f). We inline this rather than sourcing a helper because we
# need it to locate lib.sh itself.
hook_self="$0"
hook_real="$hook_self"
# Prefer readlink -f where it works (Linux; recent macOS). Probe with / so a
# BSD readlink that lacks -f doesn't dump usage to stdout.
if command -v readlink >/dev/null 2>&1 && readlink -f -- / >/dev/null 2>&1; then
  resolved="$(readlink -f -- "$hook_self" 2>/dev/null)" && [ -n "$resolved" ] && hook_real="$resolved"
elif command -v greadlink >/dev/null 2>&1; then
  resolved="$(greadlink -f "$hook_self" 2>/dev/null)" && [ -n "$resolved" ] && hook_real="$resolved"
else
  # Manual chase (BSD readlink without -f, or no readlink at all).
  hops=0
  while [ -L "$hook_real" ] && [ "$hops" -lt 40 ]; do
    hops=$((hops + 1))
    _dir="$(cd -P "$(dirname "$hook_real")" >/dev/null 2>&1 && pwd)"
    _link="$(readlink "$hook_real")"
    case "$_link" in
      /*) hook_real="$_link" ;;
      *)  hook_real="$_dir/$_link" ;;
    esac
  done
fi
hook_dir="$(cd -P "$(dirname "$hook_real")" >/dev/null 2>&1 && pwd)"
# shellcheck disable=SC1091
. "$hook_dir/lib.sh"

# ----- bypass conditions -----------------------------------------------------
[ -n "${IVT_HOOK_SKIP:-}" ] && { ivt_hook_debug "IVT_HOOK_SKIP set; exiting"; exit 0; }

prev_head="$1"
new_head="$2"
branch_flag="$3"

# Only act on branch switches (flag == 1). File checkouts (flag == 0) like
# `git checkout -- path` would otherwise fire and confuse us.
if [ "$branch_flag" != "1" ]; then
  ivt_hook_debug "not a branch switch (flag=$branch_flag); chaining & exiting"
  ivt_chain_next_hook post-checkout "$@"
  exit 0
fi

# Skip while a rebase/merge/cherry-pick is in progress — switching branches
# there is internal git machinery and the symbolic-ref may be transient.
git_dir="$(git rev-parse --git-dir 2>/dev/null || true)"
if [ -n "$git_dir" ]; then
  if [ -d "$git_dir/rebase-merge" ] || [ -d "$git_dir/rebase-apply" ] \
     || [ -f "$git_dir/MERGE_HEAD" ] || [ -f "$git_dir/CHERRY_PICK_HEAD" ]; then
    ivt_hook_debug "rebase/merge/cherry-pick in progress; chaining & exiting"
    ivt_chain_next_hook post-checkout "$@"
    exit 0
  fi
fi

new_branch="$(ivt_current_branch)"

# Detached HEAD after checkout (e.g. `git checkout <sha>`) is fine.
if [ -z "$new_branch" ]; then
  ivt_hook_debug "detached HEAD after checkout; allowed"
  ivt_chain_next_hook post-checkout "$@"
  exit 0
fi

if ivt_branch_is_valid "$new_branch"; then
  ivt_hook_debug "branch '$new_branch' is valid"
  ivt_chain_next_hook post-checkout "$@"
  exit 0
fi

# ----- the new branch is invalid — bounce back -------------------------------
cat >&2 <<EOF

[branch policy] ❌ Rejected checkout to '$new_branch'.
EOF
ivt_print_policy

# We need to switch back to $prev_head. If $prev_head is a branch tip that the
# user was ON before, `git checkout -` semantics are ideal. But $prev_head is a
# sha; recover the previously-checked-out branch name from git's reflog of HEAD.
# The entry for THIS checkout is "checkout: moving from <from> to <new_branch>";
# <from> is the branch (or sha, if previously detached) we just left.
prev_branch=""
if command -v git >/dev/null 2>&1; then
  prev_branch="$(git reflog --pretty=format:'%gs' HEAD 2>/dev/null \
    | awk -v cur="$new_branch" '
        # Match: "checkout: moving from <from> to <cur>"
        # Use a literal regex anchored on the trailing " to <cur>".
        $0 ~ ("checkout: moving from .* to "cur"$") {
          sub(/^checkout: moving from /, "")
          sub(/ to .*$/, "")
          print
          exit
        }
      ')"
  # Sanity: reject anything that still contains "checkout:" or is empty.
  case "$prev_branch" in
    ""|*"checkout:"*) prev_branch="" ;;
  esac
fi

# Restore from $prev_branch if it looks like a clean branch name, else try the
# sha directly.
restored=0
if [ -n "$prev_branch" ] && git show-ref --verify --quiet "refs/heads/$prev_branch" 2>/dev/null; then
  if git checkout --quiet "$prev_branch" 2>/dev/null; then
    restored=1
    echo "[branch policy] ↩ Switched back to '$prev_branch'." >&2
  fi
fi

if [ "$restored" -ne 1 ]; then
  # Fall back to checking out the sha we came from. Detached, but safe.
  if git checkout --quiet "$prev_head" 2>/dev/null; then
    restored=1
    echo "[branch policy] ↩ Switched back to previous commit ($prev_head, detached HEAD)." >&2
  fi
fi

if [ "$restored" -ne 1 ]; then
  echo "[branch policy] ⚠ Could not auto-switch back automatically." >&2
  echo "                  HEAD is now on '$new_branch'. Rename it with:" >&2
  echo "                    git branch -m IVT-XXXX-short-description" >&2
fi

cat >&2 <<EOF

Tip: create your branch with the task id up front and this never triggers:
    git checkout -b IVT-0999-short-description

Set IVT_HOOK_SKIP=1 to bypass for one command:
    IVT_HOOK_SKIP=1 git checkout <branch>

EOF

# Exit 0: a post-checkout hook cannot actually abort a checkout (git already
# moved HEAD). We've done the next best thing by bouncing back. Exiting
# non-zero would just print git's own "hook declined" noise.
exit 0
