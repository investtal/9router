#!/usr/bin/env bash
# installed-by: ivt-hooks
# Prepend the current branch's IVT-XXXX task id to the commit message.
#
# On a valid IVT branch the task id is extracted and prepended to the subject
# line. Skipped when the message already contains the id, or on infra branches
# (main/master/develop/release/*). A preserved commit-msg.pre-ivt is chained
# afterwards (DCO/sign-off bots keep working); its non-zero exit rejects.
#
# Bypass: git commit --no-verify skips all hooks; IVT_HOOK_SKIP=1 skips only
# the ivt prepend while still chaining the previous hook.

set -u

msg_file="$1"

# Locate the shared lib, dereferencing the installer's symlink. Portable across
# bash 3.2 (BSD readlink), macOS 12.3+, and Linux (GNU readlink -f).
hook_self="$0"
hook_real="$hook_self"
if command -v readlink >/dev/null 2>&1 && readlink -f -- / >/dev/null 2>&1; then
  resolved="$(readlink -f -- "$hook_self" 2>/dev/null)" && [ -n "$resolved" ] && hook_real="$resolved"
elif command -v greadlink >/dev/null 2>&1; then
  resolved="$(greadlink -f "$hook_self" 2>/dev/null)" && [ -n "$resolved" ] && hook_real="$resolved"
else
  hops=0
  while [ -L "$hook_real" ] && [ "$hops" -lt 40 ]; do
    hops=$((hops + 1))
    _dir="$(cd -P "$(dirname "$hook_real")" >/dev/null 2>&1 && pwd)"
    _link="$(readlink "$hook_real")"
    case "$_link" in
      /*) hook_real="$_link" ;;
      *)  hook_real="$_dir/$_link" ;;
    esac
  done
fi
hook_dir="$(cd -P "$(dirname "$hook_real")" >/dev/null 2>&1 && pwd)"
# shellcheck disable=SC1091
. "$hook_dir/lib.sh"

# Chain any previous commit-msg with the (possibly rewritten) message file,
# then propagate its exit status.
chain_and_exit() {
  ivt_chain_next_hook commit-msg "$msg_file"
  exit $?
}

[ -n "${IVT_HOOK_SKIP:-}" ] && { ivt_hook_debug "IVT_HOOK_SKIP set; still chaining"; chain_and_exit; }

branch="$(ivt_current_branch)"

[ -n "$branch" ] && ivt_branch_is_infra "$branch" && chain_and_exit

task_id=""
if [ -n "$branch" ] && [[ "$branch" =~ $IVT_TASK_REGEX ]]; then
  task_id="$(ivt_extract_task_id "$branch")"
fi
[ -z "$task_id" ] && chain_and_exit

[ -f "$msg_file" ] || chain_and_exit

msg="$(cat "$msg_file")"

# Skip if the task id is already in the real body (ignore '#' comment lines).
body_for_check="$(printf '%s\n' "$msg" | grep -v '^[[:space:]]*#' )"
# shellcheck disable=SC2076
[[ "$body_for_check" =~ $IVT_TASK_REGEX ]] && chain_and_exit

# Find the subject: first non-blank, non-comment line.
subject_line=""
subject_idx=0
i=0
while IFS= read -r line; do
  i=$((i + 1))
  case "$line" in
    ''|\#*) continue ;;
  esac
  subject_line="$line"
  subject_idx="$i"
  break
done <<EOF
$msg
EOF
[ -z "$subject_line" ] && chain_and_exit

new_subject="${task_id} ${subject_line}"

# Rewrite the subject line in place; keep all other lines byte-for-byte.
tmp="$(mktemp "${msg_file}.XXXXXX")"
trap 'rm -f "$tmp"' EXIT

i=0
wrote_subject=0
while IFS= read -r line || [ -n "$line" ]; do
  i=$((i + 1))
  if [ "$i" -eq "$subject_idx" ] && [ "$wrote_subject" -eq 0 ]; then
    printf '%s\n' "$new_subject" >>"$tmp"
    wrote_subject=1
  else
    printf '%s\n' "$line" >>"$tmp"
  fi
done <<EOF
$msg
EOF

# Preserve original trailing-newline behaviour.
if [ -n "$msg" ] && [ "${msg: -1}" != $'\n' ]; then
  printf '%s' "$(cat "$tmp")" >"$tmp"
fi

mv "$tmp" "$msg_file"
trap - EXIT
ivt_hook_debug "prepended '$task_id' to commit subject"
chain_and_exit
