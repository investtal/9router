#!/usr/bin/env bash
# installed-by: ivt-hooks
# commit-msg hook: prepend the current branch's IVT-XXXX task id to the
# commit message if it isn't already present.
#
# Behaviour:
#   • On a valid IVT branch (e.g. "feat/IVT-0999-broker"), the task id
#     "IVT-0999" is extracted and prepended to the message body.
#   • If the message already contains the task id anywhere, it is left
#     untouched (no duplicate prefixing).
#   • On infra branches (main/master/develop/release/*/hotfix/*) the hook
#     does nothing — those commits are usually merges/releases and shouldn't
#     be rewritten.
#   • Comments (#...) and trailers are preserved.
#
# Chaining:
#   A previously-installed commit-msg hook is preserved as
#   .git/hooks/commit-msg.pre-ivt and run AFTER our rewrite, with the
#   (possibly modified) message file. If it exits non-zero, the commit is
#   rejected — that propagation is intentional so e.g. a sign-off or DCO
#   gate still works.
#
# Bypass:
#   • git commit --no-verify skips this hook entirely.
#   • IVT_HOOK_SKIP=1 in the environment also skips it (but still chains
#     the previous hook, so DCO etc. are not accidentally disabled).

set -u

msg_file="$1"

# Resolve this hook's own directory, dereferencing symlinks. Portable across
# macOS bash 3.2 (BSD readlink, no -f), macOS 12.3+ (readlink -f), and Linux
# (GNU readlink -f). We inline this rather than sourcing a helper because we
# need it to locate lib.sh itself.
hook_self="$0"
hook_real="$hook_self"
if command -v readlink >/dev/null 2>&1 && readlink -f -- / >/dev/null 2>&1; then
  resolved="$(readlink -f -- "$hook_self" 2>/dev/null)" && [ -n "$resolved" ] && hook_real="$resolved"
elif command -v greadlink >/dev/null 2>&1; then
  resolved="$(greadlink -f "$hook_self" 2>/dev/null)" && [ -n "$resolved" ] && hook_real="$resolved"
else
  hops=0
  while [ -L "$hook_real" ] && [ "$hops" -lt 40 ]; do
    hops=$((hops + 1))
    _dir="$(cd -P "$(dirname "$hook_real")" >/dev/null 2>&1 && pwd)"
    _link="$(readlink "$hook_real")"
    case "$_link" in
      /*) hook_real="$_link" ;;
      *)  hook_real="$_dir/$_link" ;;
    esac
  done
fi
hook_dir="$(cd -P "$(dirname "$hook_real")" >/dev/null 2>&1 && pwd)"
# shellcheck disable=SC1091
. "$hook_dir/lib.sh"

# Run any previously-installed commit-msg hook with the (possibly rewritten)
# message file and propagate its exit status. Defined up front so every exit
# path can use it. Idempotent: if there's no .pre-ivt file, it's a no-op.
chain_and_exit() {
  ivt_chain_next_hook commit-msg "$msg_file"
  exit $?
}

# ----- bypass for OUR logic only (still chain the previous hook) -------------
if [ -n "${IVT_HOOK_SKIP:-}" ]; then
  ivt_hook_debug "IVT_HOOK_SKIP set; skipping ivt logic, still chaining"
  chain_and_exit
fi

branch="$(ivt_current_branch)"

# Infra branch → leave message alone.
if [ -n "$branch" ] && ivt_branch_is_infra "$branch"; then
  ivt_hook_debug "on infra branch '$branch'; not prepending"
  chain_and_exit
fi

# No IVT task id in branch name? Then there's nothing to prepend. Note this is
# NOT a hard reject: commit-msg runs on commits, not branches. If the user is
# on an invalid branch they were already warned at checkout time.
task_id=""
if [ -n "$branch" ] && [[ "$branch" =~ $IVT_TASK_CONTAINED_REGEX ]]; then
  task_id="$(ivt_extract_task_id "$branch")"
fi

if [ -z "$task_id" ]; then
  ivt_hook_debug "no IVT task id on branch '$branch'; nothing to prepend"
  chain_and_exit
fi

# ----- read the message body (strip comment lines) --------------------------
if [ ! -f "$msg_file" ]; then
  ivt_hook_debug "msg file '$msg_file' missing; exiting"
  chain_and_exit
fi

# Read whole file into a variable. The message is small.
msg="$(cat "$msg_file")"

# Check if the task id is already mentioned anywhere in the (real) body.
# Strip comment lines for the check so commented-out notes don't fool us.
body_for_check="$(printf '%s\n' "$msg" | grep -v '^[[:space:]]*#' )"
# shellcheck disable=SC2076
if [[ "$body_for_check" =~ $IVT_TASK_REGEX ]]; then
  ivt_hook_debug "task id already present in message; leaving untouched"
  chain_and_exit
fi

# Find the subject: first non-blank, non-comment line.
subject_line=""
subject_idx=0
i=0
while IFS= read -r line; do
  i=$((i + 1))
  case "$line" in
    ''|\#*) continue ;;
  esac
  subject_line="$line"
  subject_idx="$i"
  break
done <<EOF
$msg
EOF

if [ -z "$subject_line" ]; then
  ivt_hook_debug "empty commit body; nothing to prepend"
  chain_and_exit
fi

# Build the new message: replace the subject line in place, keep everything
# else (other body lines, blank separator, comments) byte-for-byte.
new_subject="${task_id} ${subject_line}"

# Write the file back. We do a careful line-by-line rewrite so we only touch
# the subject line.
tmp="$(mktemp "${msg_file}.XXXXXX")"
trap 'rm -f "$tmp"' EXIT

i=0
wrote_subject=0
while IFS= read -r line || [ -n "$line" ]; do
  i=$((i + 1))
  if [ "$i" -eq "$subject_idx" ] && [ "$wrote_subject" -eq 0 ]; then
    printf '%s\n' "$new_subject" >>"$tmp"
    wrote_subject=1
  else
    printf '%s\n' "$line" >>"$tmp"
  fi
done <<EOF
$msg
EOF

# Preserve the original trailing-newline behaviour: if the original file did
# NOT end with a newline, strip the one printf added. (git always supplies a
# trailing newline in practice, but be defensive.)
if [ -n "$msg" ] && [ "${msg: -1}" != $'\n' ]; then
  printf '%s' "$(cat "$tmp")" >"$tmp"
fi

mv "$tmp" "$msg_file"
trap - EXIT
ivt_hook_debug "prepended '$task_id' to commit subject"
chain_and_exit
